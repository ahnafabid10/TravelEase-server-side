{
  "swagger": "2.0",

  "info": {
    "title": "Travel Ease API",
    "version": "1.0.0",
    "description": "Travel Ease Backend API Documentation"
  },

  "host": "localhost:3000",

  "basePath": "/",

  "schemes": [
    "http"
  ],

  "consumes": [
    "application/json"
  ],

  "produces": [
    "application/json"
  ],

  "tags": [
    {
      "name": "Users",
      "description": "User Management APIs"
    },

    {
      "name": "Vehicles",
      "description": "Vehicle Management APIs"
    },

    {
      "name": "Bookings",
      "description": "Booking Management APIs"
    }
  ],

  "paths": {

    "/": {
      "get": {
        "tags": ["Home"],

        "summary": "Home Route",

        "responses": {
          "200": {
            "description": "Server running successfully"
          }
        }
      }
    },

    "/user": {

      "post": {

        "tags": ["Users"],

        "summary": "Create User",

        "description": "Create a new user",

        "parameters": [
          {
            "in": "body",

            "name": "body",

            "required": true,

            "schema": {
              "$ref": "#/definitions/User"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "User created successfully"
          }
        }
      },

      "get": {

        "tags": ["Users"],

        "summary": "Get User By Email",

        "parameters": [
          {
            "name": "email",

            "in": "query",

            "required": true,

            "type": "string"
          }
        ],

        "responses": {
          "200": {
            "description": "User fetched successfully",

            "schema": {
              "type": "array",

              "items": {
                "$ref": "#/definitions/User"
              }
            }
          }
        }
      },

      "patch": {

        "tags": ["Users"],

        "summary": "Update User",

        "parameters": [
          {
            "name": "email",

            "in": "query",

            "required": true,

            "type": "string"
          },

          {
            "in": "body",

            "name": "body",

            "required": true,

            "schema": {
              "$ref": "#/definitions/UserUpdate"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "User updated successfully"
          }
        }
      }
    },

    "/user/{id}": {

      "get": {

        "tags": ["Users"],

        "summary": "Get User By ID",

        "parameters": [
          {
            "name": "id",

            "in": "path",

            "required": true,

            "type": "string"
          }
        ],

        "responses": {
          "200": {
            "description": "Single user fetched",

            "schema": {
              "$ref": "#/definitions/User"
            }
          }
        }
      }
    },

    "/allVehicles": {

      "get": {

        "tags": ["Vehicles"],

        "summary": "Get All Vehicles",

        "responses": {
          "200": {
            "description": "Vehicles fetched successfully",

            "schema": {
              "type": "array",

              "items": {
                "$ref": "#/definitions/Vehicle"
              }
            }
          }
        }
      },

      "post": {

        "tags": ["Vehicles"],

        "summary": "Add Vehicle",

        "parameters": [
          {
            "in": "body",

            "name": "body",

            "required": true,

            "schema": {
              "$ref": "#/definitions/Vehicle"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Vehicle added successfully"
          }
        }
      }
    },

    "/allVehicles/{id}": {

      "get": {

        "tags": ["Vehicles"],

        "summary": "Get Vehicle By ID",

        "parameters": [
          {
            "name": "id",

            "in": "path",

            "required": true,

            "type": "string"
          }
        ],

        "responses": {
          "200": {
            "description": "Vehicle fetched successfully",

            "schema": {
              "$ref": "#/definitions/Vehicle"
            }
          }
        }
      },

      "put": {

        "tags": ["Vehicles"],

        "summary": "Update Vehicle",

        "parameters": [
          {
            "name": "id",

            "in": "path",

            "required": true,

            "type": "string"
          },

          {
            "in": "body",

            "name": "body",

            "required": true,

            "schema": {
              "$ref": "#/definitions/Vehicle"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Vehicle updated successfully"
          }
        }
      },

      "delete": {

        "tags": ["Vehicles"],

        "summary": "Delete Vehicle",

        "parameters": [
          {
            "name": "id",

            "in": "path",

            "required": true,

            "type": "string"
          }
        ],

        "responses": {
          "200": {
            "description": "Vehicle deleted successfully"
          }
        }
      }
    },

    "/bookNow": {

      "post": {

        "tags": ["Bookings"],

        "summary": "Book Vehicle",

        "parameters": [
          {
            "in": "body",

            "name": "body",

            "required": true,

            "schema": {
              "$ref": "#/definitions/Booking"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Booking successful"
          }
        }
      },

      "get": {

        "tags": ["Bookings"],

        "summary": "Get User Bookings",

        "parameters": [
          {
            "name": "email",

            "in": "query",

            "required": true,

            "type": "string"
          }
        ],

        "responses": {
          "200": {
            "description": "Bookings fetched successfully"
          }
        }
      }
    }
  },

  "definitions": {

    "User": {

      "type": "object",

      "properties": {

        "name": {
          "type": "string"
        },

        "email": {
          "type": "string"
        },

        "photo": {
          "type": "string"
        },

        "createdAt": {
          "type": "string"
        }
      }
    },

    "UserUpdate": {

      "type": "object",

      "properties": {

        "name": {
          "type": "string"
        },

        "photo": {
          "type": "string"
        }
      }
    },

    "Vehicle": {

      "type": "object",

      "properties": {

        "name": {
          "type": "string"
        },

        "price": {
          "type": "number"
        },

        "image": {
          "type": "string"
        },

        "location": {
          "type": "string"
        },

        "description": {
          "type": "string"
        },

        "createdAt": {
          "type": "string"
        }
      }
    },

    "Booking": {

      "type": "object",

      "properties": {

        "vehicleName": {
          "type": "string"
        },

        "bookerEmail": {
          "type": "string"
        },

        "bookingDate": {
          "type": "string"
        }
      }
    }
  }
}